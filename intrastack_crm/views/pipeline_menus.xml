<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         4 Pipeline Menu Actions
         Each action opens the CRM kanban with the correct team context
         so that team-specific stages are displayed properly.
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ─── P1 — Staffing Pipeline ──────────────────────────────────── -->
    <record id="action_crm_pipeline_p1" model="ir.actions.act_window">
        <field name="name">P1 — Staffing Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,tree,form,pivot,graph,calendar,activity</field>
        <field name="context" eval="{'default_team_id': ref('team_p1_staffing'), 'default_type': 'opportunity', 'search_default_team_id': ref('team_p1_staffing')}"/>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a new Staffing opportunity</p>
        </field>
    </record>

    <menuitem id="menu_crm_pipeline_p1"
        name="P1 — Staffing"
        parent="crm.crm_menu_root"
        action="action_crm_pipeline_p1"
        sequence="5"/>

